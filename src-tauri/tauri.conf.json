{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri2/tauri.conf.json",
  "productName": "MDium",
  "version": "0.2.0",
  "identifier": "com.mdium.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MDium",
        "width": 1400,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://asset.localhost https://asset.localhost asset: http://models.localhost https://models.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob: http://asset.localhost https://asset.localhost asset:; connect-src 'self' https: http: http://asset.localhost https://asset.localhost asset: http://models.localhost https://models.localhost; frame-src http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": [
      "../resources/slidev-env/package.json",
      "../resources/mcp-servers/**/*",
      "../resources/video-env/**/*",
      "../resources/lottie-presets/**/*",
      "../packages/open-motion/core/**/*",
      "../packages/open-motion/components/**/*",
      "../packages/open-motion/renderer/**/*",
      "../packages/open-motion/encoder/**/*",
      "../packages/open-motion/LICENSE",
      "../src/features/video/lib/composition/**/*",
      "../src/features/video/types.ts"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
